# Root environment variables template (used by docker-compose and Fly.io)
# Copy this file to .env and fill in your values.

# --- Backend: Supabase (required) ---
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Backend: MotherDuck (required) ---
MOTHERDUCK_TOKEN=your_motherduck_token

# --- Backend: Postgres (optional — defaults to local docker db) ---
# DATABASE_URL=postgresql://admin:your_db_password@db:5432/edgar_auth
